# ─── Supabase ───────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Backend API ────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_WS_URL=http://localhost:4000

# ─── Solana ─────────────────────────────────────────────────
VITE_SOLANA_NETWORK=devnet
# mainnet-beta | devnet | testnet
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
# For production: use a private RPC (Helius, QuickNode, etc.)
# VITE_SOLANA_RPC_URL=https://rpc.helius.xyz/?api-key=YOUR_KEY

# ─── CoinGecko ───────────────────────────────────────────────
VITE_COINGECKO_API_KEY=your-coingecko-api-key
# Leave blank to use free tier (rate limited)

# ─── Deployment ──────────────────────────────────────────────
# For GitHub Pages: set to /kairox (your repo name)
VITE_BASE_URL=/

# ─── Feature Flags ───────────────────────────────────────────
VITE_BETA_MODE_ENABLED=true
VITE_LIVE_MODE_ENABLED=true
VITE_DEGEN_MODE_ENABLED=true
VITE_GHOST_MODE_ENABLED=true

# ─── Solana Program ──────────────────────────────────────────
VITE_PROGRAM_ID=KRXescrow11111111111111111111111111111111111
VITE_SOLANA_WS_URL=wss://api.devnet.solana.com
# Production: use Helius/QuickNode
# VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# VITE_SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ─── Security ─────────────────────────────────────────────────
# HMAC secret for signing sensitive requests (match server)
# NEVER commit the real value — generate with: openssl rand -hex 32
VITE_HMAC_CLIENT_SECRET=changeme_in_production
