# ─── Server ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
# Production: https://yourusername.github.io

# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Use service role key on server (not anon key)

# ─── CoinGecko ───────────────────────────────────────────────
COINGECKO_API_KEY=your-coingecko-api-key

# ─── Solana ──────────────────────────────────────────────────
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Treasury wallet keypair (base58) for escrow — KEEP SECRET
# TREASURY_PRIVATE_KEY=

# ─── Game Config ─────────────────────────────────────────────
ROUND_DURATION_SECONDS=60
PRICE_POLL_MS=5000
MIN_WAGER_SOL=0.01
MAX_WAGER_SOL=10
HOUSE_EDGE=0.05

# ─── Solana Program ──────────────────────────────────────────
PROGRAM_ID=KRXescrow11111111111111111111111111111111111
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Treasury + authority keypairs — NEVER commit real keys
# AUTHORITY_PRIVATE_KEY=base58_encoded_keypair_here
# TREASURY_PUBLIC_KEY=your_treasury_wallet_pubkey

# ─── Admin ───────────────────────────────────────────────────
ADMIN_SECRET_KEY=changeme_in_production

# ─── Security ─────────────────────────────────────────────────
# HMAC secret — generate with: openssl rand -hex 32
HMAC_SECRET=changeme_in_production
# Admin panel password
ADMIN_SECRET_KEY=changeme_in_production
